# Copy this file to .env on the Raspberry Pi and fill in real values there.
# Never commit .env. Never paste secrets into chat.

TASKBRAIN_FINANCE_ENV=development
TASKBRAIN_FINANCE_DATABASE_URL=sqlite:///./data/finance.db
TASKBRAIN_FINANCE_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
TASKBRAIN_FINANCE_SESSION_SECRET=replace-with-random-session-secret

# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TASKBRAIN_FINANCE_TOKEN_ENCRYPTION_KEY=replace-with-fernet-key

PLAID_ENV=sandbox
PLAID_CLIENT_ID=replace-with-plaid-client-id
PLAID_SECRET=replace-with-plaid-secret
PLAID_PRODUCTS=transactions
PLAID_OPTIONAL_PRODUCTS=investments,liabilities

OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_MODEL=gpt-5.5

